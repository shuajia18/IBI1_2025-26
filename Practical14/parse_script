#import necessary tools
import xml.dom.minidom
import xml.sax
import datetime

#start timing
dom_start = datetime.datetime.now()
#use DOM to read .xml
DOMTree= xml.dom.minidom.parse('go_obo.xml')
root=DOMTree.documentElement
terms=root.getElementsByTagName('term')

#create a null directonary
dom_results = {
    "molecular_function": {"max_count": -1, "id": "", "name": ""},
    "biological_process": {"max_count": -1, "id": "", "name": ""},
    "cellular_component": {"max_count": -1, "id": "", "name": ""}
}

#create a new function to get the text of namespace
def get_node_text(element):
    if element and element.childNodes:
        return element.childNodes[0].data.strip()
    return ""

#start cycle to serach for each one
for term in terms:
    ns_element=term.getElementsByTagName('namespace')[0] #do not use the list,just extract it
    namespace=get_node_text(ns_element)

    #check whether the namespace is one of those three
    if namespace in dom_results:
        #get the whole is_a
        is_a_element=term.getElementsByTagName('is_a')
        #get the number of is_a
        current_count=len(is_a_element)

        #check whether it is larger than current one
        if current_count>dom_results[namespace]["max_count"]:
            id_element=term.getElementsByTagName('id')[0]
            name_element=term.getElementsByTagName('name')[0]

            #update the newest one
            dom_results[namespace]["max_count"]=current_count
            dom_results[namespace]["id"]=get_node_text(id_element)
            dom_results[namespace]["name"]=get_node_text(name_element)
    
#stop timing
dom_end=datetime.datetime.now()
dom_duration=dom_end-dom_start

print('The result for DOM analysis')
for ns,info in dom_results.items():
    print(f'The type of ontologies is {ns}')
    print('For the term has most is_a element among this typr of ontologies,')
    print(f"the ID is {info['id']}")
    print(f"the Name is {info['name']}")
    print(f"the number of is_a is {info['max_count']}")
print(f'The method of DOM use {dom_duration}')

#The method of DOM use 0:00:05.477856

#use SAX to read .xml


# tell computer what to do when encount different tags
class GOSaxHandler(xml.sax.ContentHandler):
    def __init__(self):
        #set a directionary
        self.sax_results = {
            "molecular_function": {"max_count": -1, "id": "", "name": ""},
            "biological_process": {"max_count": -1, "id": "", "name": ""},
            "cellular_component": {"max_count": -1, "id": "", "name": ""}
        }
        self.current_tag = ""
        self.current_text = ""
        self.current_id = ""
        self.current_name = ""
        self.current_namespace = ""
        self.current_is_a_count = 0

    def startElement(self, tag, attributes):
        self.current_tag = tag
        self.current_text = ""  
        if tag == "term":       
            self.current_id = ""
            self.current_name = ""
            self.current_namespace = ""
            self.current_is_a_count = 0

    
    def characters(self, content):
        self.current_text += content  

    
    def endElement(self, tag):
        val = self.current_text.strip() 
        
        if tag == "id":
            self.current_id = val
        elif tag == "name":
            self.current_name = val
        elif tag == "namespace":
            self.current_namespace = val
        elif tag == "is_a":
            self.current_is_a_count += 1  
            
        elif tag == "term": 
            ns = self.current_namespace
            if ns in self.sax_results:
                
                if self.current_is_a_count > self.sax_results[ns]["max_count"]:
                    
                    self.sax_results[ns]["max_count"] = self.current_is_a_count
                    self.sax_results[ns]["id"] = self.current_id
                    self.sax_results[ns]["name"] = self.current_name


sax_start = datetime.datetime.now()


parser = xml.sax.make_parser()
handler = GOSaxHandler()
parser.setContentHandler(handler)
parser.parse("go_obo.xml") 

# stop timing
sax_end = datetime.datetime.now()
sax_duration = sax_end - sax_start


print('The result for SAX analysis')
for ns, info in handler.sax_results.items():
    print(f'The type of ontologies is: {ns}')
    print(f"  the ID is: {info['id']}")
    print(f"  the Name is: {info['name']}")
    print(f"  the number of is_a is: {info['max_count']}\n")

print(f'The method of SAX use {sax_duration}')

#The method of SAX use 0:00:01.652080
print('The method of SAX is the quickest')
 
