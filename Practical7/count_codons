#write input code
stop_code=input('please input one of three possible	stop codons (TAA,TAG,TGA):')

#insert the file
file=open('Saccharomyces_cerevisiae.R64-1-1.cdna.all.fa','r')
content=file.read()
file.close()

import re
genes=re.split('>',content)[1:]
codon_count = {}
for gene in genes:
    lines=re.split('\n',gene)
    gene_seq_parts=lines[1:]
    gene_seq=''.join(gene_seq_parts)
#search for genes that meet requirements
    requied_genes=re.findall(rf'ATG(?:...)+?(?:{stop_code})',gene_seq)
#make filtering
    if not requied_genes:
        continue
    longest_orfs=max(requied_genes,key=len)
    coding_region=longest_orfs[:-3]
    for i in range(0,len(coding_region),3):
        codon=coding_region[i:i+3]
        if codon in codon_count:
            codon_count[codon] +=1
        else:
            codon_count[codon] =1
for c,n in codon_count.items():
    print(f'the number of {c} codons is {n}')       
import matplotlib.pyplot as plt
plt.figure(figsize=(12,12))
plt.pie(codon_count.values(),labels=codon_count.keys(),autopct='%1.1f%%',pctdistance=0.85,startangle=90)
plt.axis('equal')
plt.title(f'the distribution codons by genes contain the stop codon of {stop_code}')
plt.savefig(f'codon_plot of {stop_code}.png')
plt.close()